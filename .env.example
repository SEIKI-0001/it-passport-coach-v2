NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase is optional for local MVP development. When unset, the app uses .local-data/db.json.
# Supabase Project Settings > API > Project URL, not the dashboard URL.
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# LINE Messaging API
LINE_CHANNEL_ACCESS_TOKEN=
LINE_CHANNEL_SECRET=

# Admin area. If unset, /admin returns 404.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=
